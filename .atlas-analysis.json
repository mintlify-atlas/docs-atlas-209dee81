  "keyFeatures": [
    "Proxy API for IIUM i-Ma'luum student portal with clean JSON responses",
    "PASETO token-based authentication for stateless session management",
    "Optional API key layer for double encryption and enhanced security",
    "Concurrent web scraping using goroutines and worker pools for high performance",
    "Student academic data endpoints: profile, schedule, results, and starpoints",
    "PDF download endpoints for exam slips and study plans",
    "Optional PostgreSQL analytics for aggregate usage statistics",
    "gRPC integration with external authentication service"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
    "GET /api/auth/logout",
    "POST /api/key/generate",
    "GET /api/profile",
